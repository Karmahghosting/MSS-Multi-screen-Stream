{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MSS",
  "version": "0.3.0-pre.1",
  "identifier": "dev.mss.screenshare",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MSS — Multi-Screen Stream",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0a0e1a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/p2p-screenshare*"
    ],
    "category": "Utility",
    "shortDescription": "Direct P2P multi-monitor screen sharing.",
    "longDescription": "Capture every local screen and stream them to a connecting peer over a single TCP connection. Each remote monitor opens fullscreen on a local one. No relay, no signaling, no STUN."
  }
}
