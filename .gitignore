# Rust build outputs
/target
/dist

# Local, machine-specific Cargo overrides
# (we keep .cargo/config.toml out of the repo because it's used here only to
#  redirect target/ off a path with spaces — the GNU Rust toolchain's dlltool
#  can't handle spaces in arguments. Other contributors don't need this.)
/.cargo/config.toml

# Editors / IDEs
/.vscode
/.idea
*.iml
*.swp

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Locally-built settings (the GUI persists user prefs in localStorage / OS config dir, not here)
/settings.json

# Tauri / Node frontend build artifacts
/gui/node_modules
/gui/dist
/gui/src-tauri/target
/gui/src-tauri/gen
# The CLI is copied into gui/src-tauri/bin/ at bundle time; never commit it.
/gui/src-tauri/bin
# Cargo.lock for the gui workspace lives separately; keep it for reproducible
# builds. Uncomment if you want to ignore it instead.
